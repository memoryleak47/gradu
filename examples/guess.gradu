# guess.gradu

input_num = fn() {
    a = input();
    return a + 0;
};

# OUT: Enter secret number:
print("Enter secret number:");
secret = input_num();

running = true;
while running {
    print("Enter guessing number:");
    i = input_num();

    if i == secret {
        running = false;
        print("You got it!");
    } else {
        if i < secret {
            print("too small!");
        } else {
            print("too big!");
        }
    }
}
