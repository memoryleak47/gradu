# global.gradu

counter = 0;

fresh_int = fn() {
    global counter;

    out = counter;
    counter = counter + 1;
    return out;
};

do_stuff = fn() {
    x = fresh_int();
    print(x);

    y = fresh_int();
    print(y);
};

_ = do_stuff();

x = fresh_int();
y = fresh_int();
z = fresh_int();
print(x);
print(y);
print(z);

_ = do_stuff();

# OUT: 0
# OUT: 1
# OUT: 2
# OUT: 3
# OUT: 4
# OUT: 5
# OUT: 6
